# ============================================
# 🧱 TrichMind Node Backend — Environment Example
# ============================================

# --------------------------------------------
# Server
# --------------------------------------------
PORT=8080
NODE_ENV=development
SERVER_URL=http://localhost:8080

# --------------------------------------------
# MongoDB
# For Docker: mongodb://mongo:27017/trichmind
# For local dev: mongodb://localhost:27017/trichmind
# --------------------------------------------
MONGO_URI=mongodb://mongo:27017/trichmind

# --------------------------------------------
# ML Service Base URL
# For Docker: http://ml:8000
# For local: http://localhost:8000
# --------------------------------------------
ML_BASE_URL=http://ml:8000

# --------------------------------------------
# JWT Secrets (Change in production!)
# --------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# --------------------------------------------
# Email Configuration (Optional)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --------------------------------------------
# CORS / Frontend URL
# --------------------------------------------
CLIENT_URL=http://localhost:5050
CORS_ORIGIN=http://localhost:5050

# --------------------------------------------
# Relapse Risk Threshold
# --------------------------------------------
RELAPSE_ALERT_THRESHOLD=0.7

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_DIR=./logs
