# =============================================
# 🧱 TrichMind Backend API (.env.example)
# =============================================

PORT=8080
NODE_ENV=production

SERVER_URL=http://server:8080

# Mongo inside docker
MONGO_URI=mongodb://mongo:27017/trichmind

JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# FastAPI ML inside docker
ML_BASE_URL=http://ml:8000

# Frontend inside docker
CLIENT_URL=http://client:5000
CORS_ORIGIN=http://client:5000,http://localhost:5000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

RELAPSE_ALERT_THRESHOLD=0.7
