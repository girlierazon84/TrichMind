# server/.env.docker
# ======================================================
# 🧱 TrichMind Node Backend — Environment (Docker)
# ======================================================
DOCKERIZED=true

PORT=8080
NODE_ENV=production
SERVER_URL=http://localhost:8080

# Inside Docker network
MONGO_URI=mongodb://mongo:27017/trichmind
ML_BASE_URL=http://ml:8000

# JWT
JWT_SECRET=prod-secret
JWT_REFRESH_SECRET=prod-refresh-secret

# SMTP (prod)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini   # optional, matches your service default

# From browser perspective, you'll open http://localhost:5050
CLIENT_URL=http://localhost:5050
CORS_ORIGIN=http://localhost:5050,http://localhost:5173

RELAPSE_ALERT_THRESHOLD=0.7
LOG_DIR=./logs
