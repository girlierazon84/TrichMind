# server/.env.docker
# ============================================
# 🧱 TrichMind Node Backend — Environment (Docker)
# ============================================
DOCKERIZED=true

# --------------------------------------------
# Server
# --------------------------------------------
PORT=8080
NODE_ENV=production
SERVER_URL=http://localhost:8080

# --------------------------------------------
# MongoDB (inside Docker network)
# Other containers reach Mongo at host `mongo` port 27017
# --------------------------------------------
MONGO_URI=mongodb://mongo:27017/trichmind

# --------------------------------------------
# ML Service Base URL (inside Docker)
# Node container → FastAPI container
# --------------------------------------------
ML_BASE_URL=http://ml:8000

# --------------------------------------------
# JWT Secrets (Change in production!)
# --------------------------------------------
JWT_SECRET=prod-secret
JWT_REFRESH_SECRET=prod-refresh-secret

# --------------------------------------------
# Email Configuration (Optional)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --------------------------------------------
# CORS / Frontend URL
# From the browser’s perspective you’ll open: http://localhost:5050
# --------------------------------------------
CLIENT_URL=http://localhost:5050
CORS_ORIGIN=http://localhost:5050,http://localhost:5173

# --------------------------------------------
# Relapse Risk Threshold
# --------------------------------------------
RELAPSE_ALERT_THRESHOLD=0.7

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_DIR=./logs
