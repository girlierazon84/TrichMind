# ==================================================================
# 🧱 TrichMind Node Backend — Environment (server/.env.docker)
# ==================================================================
DOCKERIZED=true

PORT=8080
NODE_ENV=production
SERVER_URL=http://localhost:8080

# Inside Docker network
DB_NAME=trichmind_db
MONGO_URI=mongodb+srv://trichmind_user:yourPassword@trichmind-prod-servers.iahxren.mongodb.net/?appName=TrichMind-Prod-Servers
ML_BASE_URL=http://ml:8000

# JWT
JWT_SECRET=prod-secret
JWT_REFRESH_SECRET=prod-refresh-secret

# SMTP (prod / demo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# 🤖 TrichBot / OpenAI
TRICHBOT_ENABLED=false
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # add later
OPENAI_MODEL=gpt-4.1-mini

# From browser perspective, you'll open http://localhost:5050
CLIENT_URL=http://localhost:5050
CORS_ORIGIN=http://localhost:5050,http://localhost:5173

RELAPSE_ALERT_THRESHOLD=0.7
LOG_DIR=./logs
