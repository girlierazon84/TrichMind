# -------------------------------------------------------
# 🌱 TrichMind — Local Development Environment
# -------------------------------------------------------

# -------------------
# Server Configuration
# -------------------
NODE_ENV=development
PORT=8080
SERVER_URL=http://localhost:8080

# -------------------
# MongoDB Connection
# -------------------
MONGO_URI=mongodb://127.0.0.1:27017/trichmind

# -------------------
# JWT & Authentication
# -------------------
JWT_SECRET=super-secret-change-me
JWT_REFRESH_SECRET=refresh-secret-change-me

# -------------------
# ML Integration
# -------------------------------------------------------
# 🧠 This automatically works with local ML service (FastAPI)
# When running locally:
#     ML_BASE_URL=http://127.0.0.1:8000
# When running inside Docker Compose:
#     ML_BASE_URL=http://ml:8000
# -------------------------------------------------------
ML_BASE_URL=http://127.0.0.1:8000

# -------------------
# Frontend (CORS + Client URL)
# -------------------
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# -------------------
# Email (Optional for Alerts/Notifications)
# -------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# -------------------
# Relapse Alert Threshold
# -------------------
RELAPSE_ALERT_THRESHOLD=0.7

# -------------------
# Logging & Model Artifacts
# -------------------
LOG_DIR=./logs
MODEL_ARTIFACT_PATH=C:\Users\girli\OneDrive\Desktop\Portfolio-Projects\TrichMind\ml\artifacts\training_outputs\best_models
