# -----------------------
# 🌍 General Settings
# -----------------------
NODE_ENV=development
PORT=8080

# -----------------------
# 🧠 MongoDB
# -----------------------
MONGO_URI=mongodb://mongo:27017/trichmind

# -----------------------
# 🤖 ML Integration
# -----------------------
ML_BASE_URL=http://ml:8000
MODEL_PATH=artifacts/training_outputs/best_models/best_relapse_risk_predictor_model.pkl
ENCODER_PATH=artifacts/training_outputs/label_encoder/label_encoder.pkl

# -----------------------
# 🔐 JWT Secrets
# -----------------------
JWT_SECRET=super-secret-change-me
JWT_REFRESH_SECRET=refresh-secret-change-me

# -----------------------
# 📧 SMTP / Email
# -----------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# -----------------------
# 🌐 Frontend URLs
# -----------------------
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# -----------------------
# ⚙️ Server URLs
# -----------------------
SERVER_URL=http://server:8080

# -----------------------
# 🚨 Risk Thresholds
# -----------------------
RELAPSE_ALERT_THRESHOLD=0.7

# -----------------------
# 📊 Logging & Artifacts
# -----------------------
LOG_DIR=./logs
MODEL_ARTIFACT_PATH=./ml/artifacts/training_outputs/best_models
