# ============================================
# 🤖 TrichMind ML Service — Environment Example
# ============================================

# --------------------------------------------
# General
# --------------------------------------------
ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --------------------------------------------
# Model Artifacts (inside Docker container)
# --------------------------------------------
MODEL_PATH=/ml/artifacts/training_outputs/best_models/best_relapse_risk_predictor_model.pkl
ENCODER_PATH=/ml/artifacts/training_outputs/label_encoder/label_encoder.pkl
SCALER_PATH=/ml/artifacts/training_outputs/scaler.pkl
FEATURES_JSON=/ml/artifacts/training_outputs/features.json
