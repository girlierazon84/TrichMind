# ----------------------
# Server Configuration
# ----------------------
PORT=8000
TZ=Europe/Stockholm

# ------------------------------------
# Model Paths (inside the container)
# ------------------------------------
MODEL_PATH=C:\Users\girli\OneDrive\Desktop\Portfolio-Projects\TrichMind\ml\artifacts\training_outputs\best_models\best_relapse_risk_predictor_model.pkl
