# ----------------------
# Logging & Monitoring
# ----------------------
LOG_LEVEL=info

# ----------------------
# Output Directories
# ----------------------
LOG_DIR=C:\Users\girli\OneDrive\Desktop\Portfolio-Projects\TrichMind\ml\artifacts\inference_outputs\logs
