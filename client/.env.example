# ============================================
# ⚛️ TrichMind Client — Environment Example
# ============================================

# Backend API URL
# Docker Dev: http://server:8080
# Local Dev:  http://localhost:8080
NEXT_PUBLIC_API_URL=http://server:8080

# Enable stable file-watching inside Docker
CHOKIDAR_USEPOLLING=true

# Environment
NODE_ENV=development
