{
  "compilerOptions": {
    /* ---------- Core Settings ---------- */
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "resolveJsonModule": true,

    /* ---------- Type Safety ---------- */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,

    /* ---------- Next.js + Styled Components ---------- */
    "esModuleInterop": true,
    "incremental": true,

    /* ---------- Path Aliases ---------- */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* ---------- Plugins ---------- */
    "plugins": [
      { "name": "next" }
    ]
  },

  /* ---------- Include/Exclude ---------- */
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
